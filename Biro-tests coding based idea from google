## 🖱️ Option 3: Manual Client-Side Cropping System (No Server Load)
अगर किसी पेज का लेआउट बेहद अजीब है और ऑटो-क्रॉप फेल हो जाता है, तो यूजर फ्रंटएंड पर खुद क्रॉप करेगा। इसके लिए बैकएंड केवल हर पेज की एक साफ इमेज फ्रंटएंड को भेज देता है। फ्रंटएंड में react-image-crop लाइब्रेरी का इस्तेमाल करके यूजर माउस से सेलेक्ट करेगा।
## React Frontend Code (कम्पलीट वर्किंग कंपोनेंट):

import React, { useState, useRef } from 'react';
import ReactCrop from 'react-image-crop';
import 'react-image-crop/dist/ReactCrop.css';

export default function ManualCbtCropper({ pageImageUrl, onQuestionSaved }) {
  const [crop, setCrop] = useState({ unit: '%', width: 90, height: 20 });
  const [completedCrop, setCompletedCrop] = useState(null);
  const imgRef = useRef(null);

  const saveCroppedQuestion = () => {
    if (!completedCrop || !imgRef.current) return;

    const image = imgRef.current;
    const canvas = document.createElement('canvas');
    const scaleX = image.naturalWidth / image.width;
    const scaleY = image.naturalHeight / image.height;
    
    canvas.width = completedCrop.width;
    canvas.height = completedCrop.height;
    const ctx = canvas.getContext('2d');

    ctx.drawImage(
      image,
      completedCrop.x * scaleX,
      completedCrop.y * scaleY,
      completedCrop.width * scaleX,
      completedCrop.height * scaleY,
      0,
      0,
      completedCrop.width,
      completedCrop.height
    );

    // बिना सर्वर लोड के सीधे Base64 इमेज जनरेट हुई
    const base64Image = canvas.toDataURL('image/png');
    
    // इसे अपने CBT डेटाबेस के प्रश्नों में पुश कर दें
    onQuestionSaved(base64Image);
    alert("Question cropped and added to CBT successfully!");
  };

  return (
    <div style={{ padding: '20px', maxWidth: '800px', margin: '0 auto' }}>
      <h3>Option 3: Manual Drag & Drop Question Selector</h3>
      <p>माउस से ड्रैग करके प्रश्न को सेलेक्ट करें और बटन दबाएं।</p>
      
      <ReactCrop crop={crop} onChange={c => setCrop(c)} onComplete={c => setCompletedCrop(c)}>
        <img ref={imgRef} src={pageImageUrl} alt="JEE Exam Page" style={{ width: '100%' }} />
      </ReactCrop>

      <button 
        onClick={saveCroppedQuestion}
        style={{ marginTop: '15px', padding: '10px 20px', background: '#007bff', color: '#fff', border: 'none', borderRadius: '5px', cursor: 'pointer' }}
      >
        Cut & Add to Test Engine
      </button>
    </div>
  );
}

